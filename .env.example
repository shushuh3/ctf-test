# Database (Postgres) — поднимается через docker-compose
DATABASE_URL="postgresql://cft:cft_password@localhost:5432/cft?schema=public"

# Auth.js / NextAuth v5
# Сгенерировать: `openssl rand -base64 32` или `pnpm dlx auth secret`
AUTH_SECRET="change_me_use_openssl_rand_base64_32"

# Node env (development | production | test)
NODE_ENV="development"

# Логгер
LOG_LEVEL="debug"
