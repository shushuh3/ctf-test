// Схема БД для CFT Audit Portal.
// Все DateTime поля хранятся в Postgres как `timestamptz` (Prisma делает это по умолчанию).
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  L1
  L2
  L3
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Status {
  NEW
  IN_PROGRESS
  RESOLVED
  REJECTED
  CONFIRMED
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String
  role           Role
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignedResults AuditResult[] @relation("AssigneeResults")
  comments        Comment[]
  auditLogs       AuditLog[]

  @@index([role])
  @@index([isActive])
}

model System {
  id           String        @id @default(cuid())
  name         String        @unique
  module       String
  createdAt    DateTime      @default(now())
  auditResults AuditResult[]
}

model AuditResult {
  id          String    @id @default(cuid())
  title       String
  systemId    String
  system      System    @relation(fields: [systemId], references: [id])
  category    String
  description String
  severity    Severity
  status      Status    @default(NEW)
  assigneeId  String?
  assignee    User?     @relation("AssigneeResults", fields: [assigneeId], references: [id])
  foundAt     DateTime
  dueAt       DateTime?
  resolvedAt  DateTime?
  riskScore   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  comments Comment[]

  @@index([status])
  @@index([severity])
  @@index([systemId])
  @@index([assigneeId])
  @@index([foundAt])
}

model Comment {
  id            String      @id @default(cuid())
  auditResultId String
  auditResult   AuditResult @relation(fields: [auditResultId], references: [id], onDelete: Cascade)
  authorId      String
  author        User        @relation(fields: [authorId], references: [id])
  content       String
  createdAt     DateTime    @default(now())

  @@index([auditResultId])
}

// Бессхемная запись событий.
// diff храним как Json: { fieldName: [oldValue, newValue] }.
model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String // "create" | "update" | "delete" | "status_change" | "severity_change" | "comment_added"
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  diff       Json
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}
